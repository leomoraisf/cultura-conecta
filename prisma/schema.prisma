generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Artist {
  id          String   @id @default(cuid())
  name        String
  city        String
  area        String
  description String
  tags        String[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Opportunity {
  id          String   @id @default(cuid())
  title       String
  institution String
  value       String
  deadline    DateTime
  description String
  tags        String[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}